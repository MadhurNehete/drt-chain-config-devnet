FROM golang:1.23.6 AS builder
LABEL maintainer="terradharitri"

RUN apt-get update && apt-get install -y

WORKDIR /config
COPY . .

WORKDIR /go
RUN git clone https://github.com/TerraDharitri/drt-go-chain.git && cd drt-go-chain && git checkout --force $(cat /config/binaryVersion)
WORKDIR /go/drt-go-chain

#DharitrI node
WORKDIR /go/drt-go-chain/cmd/node
RUN go build -v -ldflags="-X main.appVersion=$(git --git-dir /config/.git describe --tags --long --dirty)"

RUN mkdir -p /lib_amd64 /lib_arm64

RUN cp $(go list -m -f '{{.DIR}}' github.com/TerraDharitri/drt-go-chain-vm-v)/wasmer/libwasmer_linux_amd64.so /lib_amd64/
RUN cp $(go list -m -f '{{.DIR}}' github.com/TerraDharitri/drt-go-chain-vm)/wasmer2/libvmexeccapi.so /lib_amd64/

RUN cp $(go list -m -f '{{.DIR}}' github.com/TerraDharitri/drt-go-chain-vm-v)/wasmer/libwasmer_linux_arm64_shim.so /lib_arm64/
RUN cp $(go list -m -f '{{.DIR}}' github.com/TerraDharitri/drt-go-chain-vm)/wasmer2/libvmexeccapi_arm.so /lib_arm64/

WORKDIR /config
RUN cp -r * /go/drt-go-chain/cmd/node/config/

WORKDIR /go/drt-go-chain/cmd/node

# ===== SECOND STAGE ======
FROM ubuntu:22.04
ARG TARGETARCH
RUN apt-get update -y && apt-get upgrade -y

COPY --from=builder "/go/drt-go-chain/cmd/node" "/go/drt-go-chain/cmd/node/"

# Copy architecture-specific files
COPY --from=builder "/lib_${TARGETARCH}/*" "/lib/"

WORKDIR /go/drt-go-chain/cmd/node/
EXPOSE 8080
ENTRYPOINT ["/go/drt-go-chain/cmd/node/node", "--rest-api-interface=:8080"]
